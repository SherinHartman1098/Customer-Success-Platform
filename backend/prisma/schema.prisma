generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AGENT
  MANAGER
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  TRIAL
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(AGENT)

   assignedTickets Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
}

model Customer {
  id          Int            @id @default(autoincrement())
  companyName String
  contactName String
  email       String
  phone       String?
  industry    String?
  status      CustomerStatus @default(ACTIVE)

 tickets      Ticket[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
 
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  assignedToUser Int?
  assignedUser   User? @relation(fields: [assignedToUser], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
