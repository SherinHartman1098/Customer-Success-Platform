generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AGENT
  MANAGER
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  TRIAL
}


model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(AGENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Customer {
  id           Int            @id @default(autoincrement())
  companyName  String
  contactName  String
  email        String         
  phone        String?
  industry     String?
  status       CustomerStatus @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}


